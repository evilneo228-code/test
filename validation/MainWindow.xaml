<Window x:Class="validation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Валидация данных" Height="300" Width="600"
        MinHeight="250"
        MinWidth="450"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Margin="5">
                <Button Content="Получить данные" Click="GetData" Width="120" Height="30"/>
                <TextBox x:Name="FioBox" Width="250" Margin="10,0,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="5,10,5,5">
                <Button Content="Отправить результат теста" Click="PushData" Width="120" Height="30"/>
                <TextBlock x:Name="ResultText" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>