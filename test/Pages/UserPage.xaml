<Page x:Class="test.Pages.UserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:test.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="UserPage">
    <Grid Background="#0D0D14">

        <Border Background="#13131F" CornerRadius="10"
            Width="340" Height="Auto"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            Padding="40,36">

            <StackPanel HorizontalAlignment="Center" Panel.ZIndex="1">

                <TextBlock Text="Добро пожаловать, пользователь"
                       Foreground="#C8C8E0" FontSize="18" FontWeight="SemiBold"
                       TextAlignment="Center" TextWrapping="Wrap"
                       Margin="0,0,0,28"/>

                <Button Click="BtnExit_Click"
                    Content="Выйти"
                    Padding="0,12"
                    FontSize="14" FontWeight="SemiBold"
                    Background="#6B1515" Foreground="White"
                    BorderThickness="0" Cursor="Hand"/>

            </StackPanel>
        </Border>

    </Grid>
</Page>
