<Page x:Class="test.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:test.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      MinWidth="100"
      MinHeight="100"
      Title="Страница авторизации">

    <Grid Background="#0D0D14">

        <Border Background="#13131F" CornerRadius="10"
             Width="280" Height="Auto"
             VerticalAlignment="Center"
             HorizontalAlignment="Center"
             Padding="28,32">

            <StackPanel>
                <!-- Логин -->
                <TextBlock Text="Логин"
                        Foreground="#606078" FontSize="11"
                        Margin="0,0,0,4"/>
                <TextBox Name="TxbLogin"
                      Padding="8,7" FontSize="13"
                      Background="#08080F" Foreground="#C8C8E0"
                      BorderBrush="#2A2A44" BorderThickness="1"
                      CaretBrush="#6060CC"
                      Margin="0,0,0,14"/>

                <!-- Пароль -->
                <TextBlock Text="Пароль"
                        Foreground="#606078" FontSize="11"
                        Margin="0,0,0,4"/>
                <TextBox Name="TxbPassword"
                      Padding="8,7" FontSize="13"
                      Background="#08080F" Foreground="#C8C8E0"
                      BorderBrush="#2A2A44" BorderThickness="1"
                      CaretBrush="#6060CC"
                      Margin="0,0,0,24"/>

                <!-- Кнопка -->
                <Button Click="BtnSign_Click"
                     Content="Войти"
                     Padding="0,10"
                     FontSize="13" FontWeight="SemiBold"
                     Background="#3A3ACC" Foreground="White"
                     BorderThickness="0" Cursor="Hand"/>

            </StackPanel>
        </Border>

    </Grid>
</Page>
