<Page x:Class="test.Pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Панель администратора">

    <Grid Background="#0D0D14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель: форма слева, кнопки справа -->
        <Border Grid.Row="0" Background="#13131F" CornerRadius="10"
                Margin="12,12,12,6" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="160"/>
                </Grid.ColumnDefinitions>

                <!-- Левая часть: поля формы -->
                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <TextBlock Text="РЕДАКТИРОВАНИЕ ПОЛЬЗОВАТЕЛЯ"
                               Foreground="#6060CC" FontSize="11" FontWeight="Bold"
                               Margin="0,0,0,14"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Логин -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Логин" Foreground="#606078"
                                   FontSize="11" Margin="0,0,12,4"/>
                        <TextBox x:Name="TxbLogin"
                                 Grid.Row="1" Grid.Column="0"
                                 Margin="0,0,12,12" Padding="8,6" FontSize="13"
                                 Background="#08080F" Foreground="#C8C8E0"
                                 BorderBrush="#2A2A44" BorderThickness="1"
                                 CaretBrush="#6060CC"/>

                        <!-- Пароль -->
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="Пароль" Foreground="#606078"
                                   FontSize="11" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxbPassword"
                                 Grid.Row="1" Grid.Column="1"
                                 Margin="0,0,0,12" Padding="8,6" FontSize="13"
                                 Background="#08080F" Foreground="#C8C8E0"
                                 BorderBrush="#2A2A44" BorderThickness="1"
                                 CaretBrush="#6060CC"/>

                        <!-- Роль -->
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Роль" Foreground="#606078"
                                   FontSize="11" Margin="0,0,12,4"/>
                        <ComboBox x:Name="CmbRole"
                                  Grid.Row="3" Grid.Column="0"
                                  Margin="0,0,12,0" Padding="8,6" FontSize="13"
                                  Background="#08080F" Foreground="#C8C8E0"
                                  BorderBrush="#2A2A44" BorderThickness="1">
                            <ComboBoxItem Content="Пользователь"/>
                            <ComboBoxItem Content="Администратор"/>
                        </ComboBox>

                        <!-- Заблокирован -->
                        <CheckBox x:Name="ChkBlocked"
                                  Grid.Row="3" Grid.Column="1"
                                  Content="Заблокирован"
                                  Foreground="#CC5555"
                                  FontSize="13"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <!-- Правая часть: кнопки -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,28,0,0">
                    <Button Content="Добавить" Click="BtnAdd_Click"
                            Margin="0,0,0,8" Padding="0,10"
                            FontSize="13" FontWeight="SemiBold"
                            Background="#3A3ACC" Foreground="White"
                            BorderThickness="0" Cursor="Hand"/>
                    <Button Content="Обновить" Click="BtnUpdate_Click"
                            Margin="0,0,0,8" Padding="0,10"
                            FontSize="13" FontWeight="SemiBold"
                            Background="#1E6640" Foreground="White"
                            BorderThickness="0" Cursor="Hand"/>
                    <Button Content="Очистить" Click="BtnClear_Click"
                            Margin="0,0,0,8" Padding="0,10"
                            FontSize="13" FontWeight="SemiBold"
                            Background="#2A2A3A" Foreground="#9090AA"
                            BorderThickness="0" Cursor="Hand"/>
                    <Button Content="Выход" Click="BtnExit_Click"
                            Margin="0,0,0,0" Padding="0,10"
                            FontSize="13" FontWeight="SemiBold"
                            Background="#6B1515" Foreground="White"
                            BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Нижняя панель: список пользователей -->
        <Border Grid.Row="1" Background="#13131F" CornerRadius="10"
                Margin="12,6,12,12" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="ПОЛЬЗОВАТЕЛИ" Foreground="#6060CC"
                           FontSize="11" FontWeight="Bold"
                           Margin="0,0,0,10"/>
                <ListBox x:Name="LbUsers"
                         Grid.Row="1"
                         SelectionChanged="LbUsers_SelectionChanged"
                         Background="#08080F"
                         Foreground="#C8C8E0"
                         BorderBrush="#2A2A44" BorderThickness="1"
                         FontSize="13"/>
            </Grid>
        </Border>
    </Grid>
</Page>